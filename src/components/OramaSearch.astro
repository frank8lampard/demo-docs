---
// OramaSearch.astro — замена стандартного поиска Starlight на Orama
// Индекс собирается скриптом scripts/build-search-index.mjs
---

<div class="orama-search-wrap">
  <button id="orama-trigger" type="button" aria-label="Search">
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
    </svg>
    <span class="orama-trigger-label">\u041f\u043e\u0438\u0441\u043a\u2026</span>
    <kbd>Ctrl+K</kbd>
  </button>
</div>

<dialog id="orama-dialog" aria-label="\u041f\u043e\u0438\u0441\u043a">
  <div class="orama-modal">
    <div class="orama-input-row">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
           stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
           class="orama-input-icon">
        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
      <input id="orama-input" type="search" autocomplete="off" spellcheck="false"
             placeholder="\u041f\u043e\u0438\u0441\u043a \u043f\u043e \u0434\u043e\u043a\u0443\u043c\u0435\u043d\u0442\u0430\u0446\u0438\u0438\u2026" />
      <button id="orama-close" type="button" aria-label="\u0417\u0430\u043a\u0440\u044b\u0442\u044c">Esc</button>
    </div>
    <div id="orama-results" role="listbox"></div>
    <div id="orama-empty" class="orama-empty" hidden>
      \u041d\u0438\u0447\u0435\u0433\u043e \u043d\u0435 \u043d\u0430\u0439\u0434\u0435\u043d\u043e
    </div>
  </div>
</dialog>

<style>
  .orama-search-wrap {
    flex: 1;
    display: flex;
    align-items: center;
  }

  #orama-trigger {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
    max-width: 500px;
    padding: 0.4rem 0.75rem;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 6px;
    color: rgba(255,255,255,0.7);
    font-size: 0.875rem;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s;
  }
  #orama-trigger:hover {
    background: rgba(255,255,255,0.15);
    border-color: rgba(255,255,255,0.35);
  }
  .orama-trigger-label { flex: 1; text-align: left; }
  #orama-trigger kbd {
    font-size: 0.7rem;
    padding: 2px 5px;
    border-radius: 4px;
    background: rgba(255,255,255,0.15);
    border: 1px solid rgba(255,255,255,0.2);
    font-family: inherit;
  }

  /* Диалог */
  #orama-dialog {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    max-width: 100%;
    max-height: 100%;
    background: rgba(0,0,0,0.6);
    border: none;
    padding: 0;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 80px;
  }
  #orama-dialog::backdrop { display: none; }

  .orama-modal {
    width: 100%;
    max-width: 600px;
    background: var(--sl-color-bg);
    border: 1px solid var(--sl-color-hairline-light);
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0,0,0,0.4);
  }

  .orama-input-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--sl-color-hairline-light);
  }
  .orama-input-icon { flex-shrink: 0; opacity: 0.5; color: var(--sl-color-text); }
  #orama-input {
    flex: 1;
    border: none;
    background: transparent;
    font-size: 1rem;
    color: var(--sl-color-text);
    outline: none;
  }
  #orama-input::placeholder { color: var(--sl-color-gray-4); }
  #orama-input::-webkit-search-cancel-button { display: none; }

  #orama-close {
    font-size: 0.7rem;
    padding: 3px 7px;
    border-radius: 4px;
    background: var(--sl-color-bg-nav);
    border: 1px solid var(--sl-color-hairline-light);
    color: var(--sl-color-gray-3);
    cursor: pointer;
    flex-shrink: 0;
  }

  /* Результаты */
  #orama-results { max-height: 420px; overflow-y: auto; }

  .orama-result {
    display: block;
    padding: 0.75rem 1rem;
    text-decoration: none;
    border-bottom: 1px solid var(--sl-color-hairline-light);
    transition: background 0.1s;
    cursor: pointer;
  }
  .orama-result:last-child { border-bottom: none; }
  .orama-result:hover, .orama-result[aria-selected="true"] {
    background: var(--sl-color-bg-nav);
  }
  .orama-result-section {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--sl-color-accent);
    font-weight: 600;
    margin-bottom: 2px;
  }
  .orama-result-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--sl-color-text);
    margin-bottom: 3px;
  }
  .orama-result-excerpt {
    font-size: 0.82rem;
    color: var(--sl-color-gray-3);
    line-height: 1.4;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
  .orama-result-excerpt mark {
    background: rgba(55,138,221,0.25);
    color: var(--sl-color-text);
    border-radius: 2px;
    padding: 0 2px;
    font-weight: bold;
  }

  .orama-empty {
    padding: 2rem;
    text-align: center;
    color: var(--sl-color-gray-3);
    font-size: 0.9rem;
  }
</style>

<script>
  import { restore } from '@orama/plugin-data-persistence'
  import { search } from '@orama/orama'

  const BASE = (document.querySelector('base')?.getAttribute('href') || '').replace(/\/$/, '')
  const INDEX_URL = BASE + '/search-index.json'

  let db = null
  let dbLoading = false

  async function loadDb() {
    if (db) return db
    if (dbLoading) return null
    dbLoading = true
    const res = await fetch(INDEX_URL)
    const json = await res.text()
    db = await restore('json', json)
    return db
  }

  const dialog  = document.getElementById('orama-dialog')
  const trigger = document.getElementById('orama-trigger')
  const input   = document.getElementById('orama-input')
  const results = document.getElementById('orama-results')
  const empty   = document.getElementById('orama-empty')
  const closeBtn = document.getElementById('orama-close')

  function openDialog() {
    dialog.showModal ? dialog.showModal() : (dialog.open = true)
    input.focus()
    loadDb()
  }

  function closeDialog() {
    dialog.close ? dialog.close() : (dialog.open = false)
    input.value = ''
    results.innerHTML = ''
    empty.hidden = true
  }

  trigger.addEventListener('click', openDialog)
  closeBtn.addEventListener('click', closeDialog)

  dialog.addEventListener('click', function(e) {
    if (e.target === dialog) closeDialog()
  })

  document.addEventListener('keydown', function(e) {
    if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
      e.preventDefault()
      openDialog()
    }
    if (e.key === 'Escape' && (dialog.open)) {
      closeDialog()
    }
  })

  function highlight(text, term) {
    if (!term) return text
    const escaped = term.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')
    return text.replace(new RegExp('(' + escaped + ')', 'gi'), '<mark>$1</mark>')
  }

  function renderResults(hits, term) {
    results.innerHTML = ''
    empty.hidden = true

    if (hits.length === 0) {
      empty.hidden = false
      return
    }

    hits.forEach(function(hit) {
      const doc = hit.document
      const a = document.createElement('a')
      a.className = 'orama-result'
      a.href = doc.url
      a.setAttribute('role', 'option')

      const excerpt = doc.content
        ? highlight(doc.content.slice(0, 140) + '\u2026', term)
        : ''

      a.innerHTML =
        '<div class="orama-result-section">' + doc.section + '</div>' +
        '<div class="orama-result-title">' + highlight(doc.title, term) + '</div>' +
        '<div class="orama-result-excerpt">' + excerpt + '</div>'

      a.addEventListener('click', function() { closeDialog() })
      results.appendChild(a)
    })
  }

  let debounceTimer = null
  input.addEventListener('input', function() {
    clearTimeout(debounceTimer)
    const term = input.value.trim()
    if (!term) {
      results.innerHTML = ''
      empty.hidden = true
      return
    }
    debounceTimer = setTimeout(async function() {
      const database = await loadDb()
      if (!database) return
      const r = await search(database, { term, tolerance: 1, limit: 8 })
      renderResults(r.hits, term)
    }, 150)
  })
</script>
